      "isDeleted": true,
      "boundElements": null,
      "updated": 1772359456225,
      "link": null,
      "locked": false,
      "text": "Users send requests from the Internet\nRequests first pass through AWS WAF\nWAF inspects the request based on rules\nMalicious traffic → Blocked\nLegitimate traffic → Allowed to reach the application",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Users send requests from the Internet\nRequests first pass through AWS WAF\nWAF inspects the request based on rules\nMalicious traffic → Blocked\nLegitimate traffic → Allowed to reach the application",
      "autoResize": true,
      "lineHeight": 1.25
    },
