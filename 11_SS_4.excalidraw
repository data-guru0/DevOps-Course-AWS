      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GuardDuty generates alerts called Findings.\nEach finding includes:\n    Threat type\n    Affected resource\n    Severity level\n    Time detected",
