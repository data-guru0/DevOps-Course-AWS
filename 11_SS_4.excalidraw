    {
      "id": "lvrl34PCPcBdNlk7juXNW",
      "type": "text",
      "x": 432.02692857165107,
      "y": 599.7791608663332,
      "width": 520.5196533203125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
