      "isDeleted": true,
      "boundElements": null,
      "updated": 1772359456225,
      "link": null,
      "locked": false,
      "text": "AWS WAF is a web application firewall that helps protect web applications from common web exploits.\nIt monitors and filters HTTP/HTTPS requests reaching your application.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AWS WAF is a web application firewall that helps protect web applications from common web exploits.\nIt monitors and filters HTTP/HTTPS requests reaching your application.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4R0BvULS_tZ1ql-X-9QTl",
