      "seed": 709568087,
      "version": 37,
      "versionNonce": 766824601,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1772359456225,
      "link": null,
      "locked": false,
      "text": "A Web ACL is a set of security rules in AWS WAF \nthat controls how incoming web requests are handled.\nIt determines whether a request should be:\n    Allowed\n    BlockeD\n    Counted (for monitoring)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A Web ACL is a set of security rules in AWS WAF \nthat controls how incoming web requests are handled.\nIt determines whether a request should be:\n    Allowed\n    BlockeD\n    Counted (for monitoring)",
      "autoResize": true,
      "lineHeight": 1.25
    },
