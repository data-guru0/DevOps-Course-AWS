      "boundElements": [],
      "updated": 1772349392252,
      "link": null,
      "locked": false,
      "text": "Example Use Case:\nA company stores customer files in Amazon S3.\nUsing KMS:\n    Files are encrypted before storage\n    Only authorized users with correct permissions can decrypt them.\n    This ensures data confidentiality",
      "fontSize": 19.573331705729156,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Example Use Case:\nA company stores customer files in Amazon S3.\nUsing KMS:\n    Files are encrypted before storage\n    Only authorized users with correct permissions can decrypt them.\n    This ensures data confidentiality",
      "autoResize": true,
      "lineHeight": 1.25
    },
