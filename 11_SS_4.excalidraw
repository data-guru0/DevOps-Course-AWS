      "isDeleted": false,
      "boundElements": null,
      "updated": 1772360328174,
      "link": null,
      "locked": false,
      "text": "Amazon GuardDuty is a threat detection service that continuously monitors your AWS environment to identify\nmalicious activity and unauthorized behavior.\nIt uses machine learning, anomaly detection, and threat intelligence.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Amazon GuardDuty is a threat detection service that continuously monitors your AWS environment to identify\nmalicious activity and unauthorized behavior.\nIt uses machine learning, anomaly detection, and threat intelligence.",
      "autoResize": true,
      "lineHeight": 1.25
    },
