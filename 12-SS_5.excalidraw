    {
      "id": "bTlCbBIzN9GXMyMt9MJ-_",
      "type": "text",
      "x": 884.800048828125,
      "y": 305.79998779296875,
      "width": 548.0394897460938,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
