      "isDeleted": false,
      "boundElements": [],
      "updated": 1772367964032,
      "link": null,
      "locked": false,
      "text": "Amazon Inspector is an automated security assessment service that scans\nAWS workloads to identify vulnerabilities and security issues.\nIt continuously checks resources such as EC2 instances and container images for security risks.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Amazon Inspector is an automated security assessment service that scans\nAWS workloads to identify vulnerabilities and security issues.\nIt continuously checks resources such as EC2 instances and container images for security risks.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
