      "text": "AWS Inspector looks for:",
      "fontSize": 21.91999511718752,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AWS Inspector looks for:",
