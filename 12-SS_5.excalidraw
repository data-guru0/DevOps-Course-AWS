      "updated": 1772368263461,
      "link": null,
      "locked": false,
      "text": "1️⃣ AWS resources (EC2, containers) are monitored\n2️⃣ Inspector scans the system for vulnerabilities\n3️⃣ Detected risks are analyzed\n4️⃣ Security findings are generated\n5️⃣ Alerts are sent to security teams",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1️⃣ AWS resources (EC2, containers) are monitored\n2️⃣ Inspector scans the system for vulnerabilities\n3️⃣ Detected risks are analyzed\n4️⃣ Security findings are generated\n5️⃣ Alerts are sent to security teams",
      "autoResize": true,
      "lineHeight": 1.25
    },
