      "versionNonce": 396280599,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772368173464,
      "link": null,
      "locked": false,
      "text": "Amazon Inspector currently scans:\n\n• EC2 instances\n• Amazon ECR container images\n• AWS Lambda functions (for vulnerabilities in packages)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Amazon Inspector currently scans:\n\n• EC2 instances\n• Amazon ECR container images\n• AWS Lambda functions (for vulnerabilities in packages)",
