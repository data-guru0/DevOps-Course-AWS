      "isDeleted": false,
      "boundElements": null,
      "updated": 1772374019993,
      "link": null,
      "locked": false,
      "text": "Example Use Case\n\nA company stores customer records in an S3 bucket.\nMacie scans the bucket and discovers files containing:\nCredit card numbers\nCustomer personal information\nMacie then generates a security alert so the organization can secure the data.",
      "fontSize": 16.45140726253218,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Example Use Case\n\nA company stores customer records in an S3 bucket.\nMacie scans the bucket and discovers files containing:\nCredit card numbers\nCustomer personal information\nMacie then generates a security alert so the organization can secure the data.",
      "autoResize": true,
      "lineHeight": 1.25
    },
