    {
      "id": "4dm34wEpLUmtl_MT6jOzN",
      "type": "text",
      "x": 901.9998779296875,
      "y": 2971.199884033205,
      "width": 610.431396484375,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aq",
      "roundness": null,
      "seed": 1456881994,
      "version": 74,
      "versionNonce": 1081956054,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "TbFWa22LQ4U5xHH9DOLny",
          "type": "arrow"
        }
      ],
      "updated": 1772374035745,
      "link": null,
      "locked": false,
      "text": "This diagram shows how different AWS security services work together\n to protect cloud applications and data. Internet traffic first passes \nthrough AWS Shield to protect against DDoS attacks and then through\n AWS WAF, which filters malicious web requests before reaching the application\n servers. Activity logs such as VPC Flow Logs, CloudTrail Logs, and DNS Logs\n are collected and analyzed by services like Amazon GuardDuty to detect\n threats. Amazon Inspector scans resources for vulnerabilities, while \nAmazon Macie analyzes S3 buckets to identify sensitive data. AWS KMS\n manages encryption keys to secure data, and all security findings are \ncentralized in AWS Security Hub for monitoring and response.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This diagram shows how different AWS security services work together\n to protect cloud applications and data. Internet traffic first passes \nthrough AWS Shield to protect against DDoS attacks and then through\n AWS WAF, which filters malicious web requests before reaching the application\n servers. Activity logs such as VPC Flow Logs, CloudTrail Logs, and DNS Logs\n are collected and analyzed by services like Amazon GuardDuty to detect\n threats. Amazon Inspector scans resources for vulnerabilities, while \nAmazon Macie analyzes S3 buckets to identify sensitive data. AWS KMS\n manages encryption keys to secure data, and all security findings are \ncentralized in AWS Security Hub for monitoring and response.",
      "autoResize": true,
      "lineHeight": 1.25
    },
