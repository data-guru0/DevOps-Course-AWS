      "updated": 1772372821920,
      "link": null,
      "locked": false,
      "text": "Macie can detect sensitive data like:\nCredit card numbers\nSocial security numbers\nEmail addresses\nPhone numbers\nAPI keys\nPasswords",
      "fontSize": 19.81714564732143,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Macie can detect sensitive data like:\nCredit card numbers\nSocial security numbers\nEmail addresses\nPhone numbers\nAPI keys\nPasswords",
