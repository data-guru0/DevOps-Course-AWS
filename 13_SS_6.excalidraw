    {
      "id": "7KumICNM1a-qOhmAjbsks",
      "type": "text",
      "x": 103.19999694824219,
      "y": 2517.9998779296884,
      "width": 493.0235595703125,
      "height": 140,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "am",
      "roundness": null,
      "seed": 662520278,
      "version": 110,
      "versionNonce": 228890186,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772373692106,
      "link": null,
      "locked": false,
      "text": "The Findings section shows security alerts \ngenerated when Macie detects sensitive data or security risks.\nEach finding includes:\n    Type of sensitive data detected\n    S3 bucket name\n    Severity level\n    Time detected",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The Findings section shows security alerts \ngenerated when Macie detects sensitive data or security risks.\nEach finding includes:\n    Type of sensitive data detected\n    S3 bucket name\n    Severity level\n    Time detected",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "3c8UzB9gISUdnrUr8hpxb",
      "type": "text",
      "x": 241.98763704439625,
      "y": 613.0000793457029,
      "width": 680.3284912109375,
      "height": 159.085693359375,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "an",
      "roundness": null,
      "seed": 1349736726,
      "version": 77,
      "versionNonce": 693354570,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772373798038,
      "link": null,
      "locked": false,
      "text": "A Macie Job is a task that scans selected Amazon S3 buckets\nto identify sensitive data such as:\n    Credit card numbers\n    Email addresses\n    Phone numbers\n    Passwords\n    Personal identifiable information (PII)\n    Macie analyzes the data and generates findings if sensitive information is detected.",
      "fontSize": 15.9085693359375,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A Macie Job is a task that scans selected Amazon S3 buckets\nto identify sensitive data such as:\n    Credit card numbers\n    Email addresses\n    Phone numbers\n    Passwords\n    Personal identifiable information (PII)\n    Macie analyzes the data and generates findings if sensitive information is detected.",
      "autoResize": true,
      "lineHeight": 1.25
    },
