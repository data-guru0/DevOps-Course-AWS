    {
      "id": "Ycf6MJZxmhHGbaDvbfXvi",
      "type": "text",
      "x": 390,
      "y": -190.9333038330078,
      "width": 821.87939453125,
      "height": 175,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a3",
      "roundness": null,
      "seed": 1178142742,
      "version": 81,
      "versionNonce": 1200505302,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772372816786,
      "link": null,
      "locked": false,
      "text": "Amazon Macie is a data security and privacy service that uses machine learning\nto automatically discover, classify, and protect sensitive data stored in Amazon S3.\nIt helps identify sensitive information such as:\n    Personally Identifiable Information (PII)\n    Financial data\n    Passwords\n    API keys",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Amazon Macie is a data security and privacy service that uses machine learning\nto automatically discover, classify, and protect sensitive data stored in Amazon S3.\nIt helps identify sensitive information such as:\n    Personally Identifiable Information (PII)\n    Financial data\n    Passwords\n    API keys",
      "autoResize": true,
      "lineHeight": 1.25
    },
